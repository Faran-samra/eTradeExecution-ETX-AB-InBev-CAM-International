# =====================================================================
# Variables de entorno - AB InBev Trade Platform
# Copia este archivo a .env.local y rellena los valores reales.
# =====================================================================

# Supabase (base de datos + autenticación)
# Obtén estos valores en: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_publica

# Claude / Anthropic API (para análisis IA de góndolas)
# IMPORTANTE: En producción NUNCA expongas esto en frontend.
# Usar una Edge Function de Supabase como proxy. Ver docs/SETUP.md
VITE_AI_PROXY_URL=https://tu-proyecto.supabase.co/functions/v1/analyze-shelf

# Configuración opcional
VITE_DEFAULT_LOCALE=es-PA
VITE_APP_NAME="Trade Survey"
